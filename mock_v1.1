        // =========================================================================
        function startExam() {
            aspirantName = document.getElementById('aspirant-name').value.trim();
            
            if (!aspirantName) {
                alert("Please enter your Full Name.");
                return;
            }

            // Capture initial ID photo
            captureSnapshot();

            // Request Fullscreen
            if (document.documentElement.requestFullscreen) {
                document.documentElement.requestFullscreen().catch((err) => {
                    logViolation("Failed to enter fullscreen initially.");
                });
            }

            // Setup UI
            document.getElementById('display-cand-name').innerText = aspirantName;
            renderSidebar();
            renderQuestions(activeModule);
            
            // Start Timers & Trackers
            isExamActive = true;
            examTimer = setInterval(updateTimer, 1000);
            
            // Random snapshots (every ~10 mins, scaled down for demo to 30 secs)
            snapshotInterval = setInterval(captureSnapshot, 1000 * 30);

            // Add anti-cheat listeners
            document.addEventListener("visibilitychange", handleVisibilityChange);
            document.addEventListener("fullscreenchange", handleFullscreenChange);

            logViolation("Exam Started.");
            switchScreen('screen-exam');
        }

        function updateTimer() {
            if (totalSeconds <= 0) {
                clearInterval(examTimer);
                submitExam();
                return;
            }
            totalSeconds--;
            const h = Math.floor(totalSeconds / 3600).toString().padStart(2, '0');
            const m = Math.floor((totalSeconds % 3600) / 60).toString().padStart(2, '0');
            const s = (totalSeconds % 60).toString().padStart(2, '0');
            document.getElementById('timer-display').innerText = `${h}:${m}:${s}`;
        }

        // =========================================================================
        // ANTI-CHEAT MECHANISMS
        // =========================================================================
        function logViolation(message) {
            const time = new Date().toLocaleTimeString();
            cheatLogs.push(`[${time}] ${message}`);
        }

        function handleVisibilityChange() {
            if (isExamActive && document.hidden) {
                logViolation("Tab switched or browser minimized.");
                showWarningOverlay();
            }
        }

        function handleFullscreenChange() {
            if (isExamActive && !document.fullscreenElement) {
                logViolation("Exited fullscreen mode.");
                showWarningOverlay();
            }
        }

        function showWarningOverlay() {
            document.getElementById('fullscreen-warning').classList.remove('hidden-screen');
        }

        function returnToExam() {
            if (document.documentElement.requestFullscreen) {
                document.documentElement.requestFullscreen();
            }
            document.getElementById('fullscreen-warning').classList.add('hidden-screen');
        }

        // =========================================================================
        // RENDER LOGIC
        // =========================================================================
        function renderSidebar() {
            const ul = document.getElementById('module-tabs');
            ul.innerHTML = '';
            examData.modules.forEach(mod => {
                const li = document.createElement('li');
                const btn = document.createElement('button');
                btn.className = `w-full text-left px-4 py-2 rounded-md text-sm transition-colors ${mod === activeModule ? 'bg-blue-600 text-white font-semibold' : 'hover:bg-slate-700 text-slate-300'}`;
                btn.innerText = mod;
                btn.onclick = () => {
                    activeModule = mod;
                    renderSidebar();
                    renderQuestions(mod);
                };
                li.appendChild(btn);
                ul.appendChild(li);
            });
        }

        function renderQuestions(moduleName) {
            const container = document.getElementById('questions-container');
            container.innerHTML = `<h2 class="text-2xl font-bold text-slate-800 mb-6 border-b pb-2">${moduleName}</h2>`;
            
            const moduleQs = examData.questions.filter(q => q.module === moduleName);
            
            moduleQs.forEach((q, index) => {
                const qDiv = document.createElement('div');
                qDiv.className = "bg-white p-6 rounded-xl border border-slate-200 shadow-sm mb-6";
                
                // Text formatting to handle newlines
                const formattedText = q.text.replace(/\n/g, '<br/>');

                let html = `<p class="font-medium text-slate-800 mb-4 text-base"><span class="text-slate-400 mr-2">Q${q.id}.</span>${formattedText}</p><div class="space-y-2">`;
                
                q.options.forEach((opt, optIdx) => {
                    const isChecked = candidateAnswers[q.id] === optIdx ? 'checked' : '';
                    const radioId = `q_${q.id}_opt_${optIdx}`;
                    html += `
                        <label class="flex items-start p-3 border rounded-lg cursor-pointer hover:bg-slate-50 transition-colors ${isChecked ? 'border-blue-500 bg-blue-50' : 'border-slate-200'}">
                            <input type="radio" name="q_${q.id}" value="${optIdx}" ${isChecked} class="mt-1 mr-3 text-blue-600 focus:ring-blue-500" onchange="saveAnswer(${q.id}, ${optIdx})">
                            <span class="text-sm text-slate-700">${String.fromCharCode(65 + optIdx)}. ${opt}</span>
                        </label>
                    `;
                });
                html += `</div>`;
                qDiv.innerHTML = html;
                container.appendChild(qDiv);
            });
        }

        function saveAnswer(qId, optIdx) {
            candidateAnswers[qId] = optIdx;
        }

        // =========================================================================
        // EXAM SUBMISSION & ENCRYPTION
        // =========================================================================
        function confirmSubmission() {
            if(confirm("Are you sure you want to submit? You cannot return to the exam.")) {
                submitExam();
            }
        }

        function submitExam() {
            isExamActive = false;
            clearInterval(examTimer);
            clearInterval(snapshotInterval);
            document.removeEventListener("visibilitychange", handleVisibilityChange);
            document.removeEventListener("fullscreenchange", handleFullscreenChange);
            
            // Stop Camera
            if (streamRef) {
                streamRef.getTracks().forEach(track => track.stop());
            }

            // Capture Final photo
            captureSnapshot();
            logViolation("Exam Submitted.");

            if (document.exitFullscreen) document.exitFullscreen().catch(()=>{});

            processResults();
        }

        function processResults() {
            let totalCorrect = 0;
            const sectionStats = {};
            examData.modules.forEach(m => sectionStats[m] = { total: 0, correct: 0 });

            examData.questions.forEach(q => {
                sectionStats[q.module].total++;
                if (candidateAnswers[q.id] === q.correctIndex) {
                    totalCorrect++;
                    sectionStats[q.module].correct++;
                }
            });

            const percentage = Math.round((totalCorrect / examData.questions.length) * 100);
            const passed = percentage >= 80;

            // Generate Payload for encryption
            const reportData = {
                candidateName: aspirantName,
                totalScore: totalCorrect,
                totalQuestions: examData.questions.length,
                percentage: percentage,
                sectionStats: sectionStats,
                candidateAnswers: candidateAnswers,
                cheatLogs: cheatLogs,
                images: capturedImages,
                timestamp: new Date().toISOString()
            };

            // Encrypt Data
            const jsonString = JSON.stringify(reportData);
            const encryptedData = CryptoJS.AES.encrypt(jsonString, EXAM_PASSWORD).toString();

            // Store in global variable for download button
            window.finalEncryptedData = encryptedData;

            // Render Result Screen
            switchScreen('screen-result');
            document.getElementById('result-score').innerText = `${percentage}%`;

            if (passed) {
                document.getElementById('result-icon').innerHTML = `<svg class="w-16 h-16 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`;
                document.getElementById('result-title').innerText = "Outstanding Performance!";
                document.getElementById('result-title').classList.add('text-emerald-600');
                document.getElementById('result-card').classList.add('glow-success');
                fireConfetti();
            } else {
                document.getElementById('result-icon').innerHTML = `<svg class="w-16 h-16 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`;
            }
        }

        function fireConfetti() {
            var duration = 3000;
            var animationEnd = Date.now() + duration;
            var defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 100 };

            function randomInRange(min, max) { return Math.random() * (max - min) + min; }

            var interval = setInterval(function() {
                var timeLeft = animationEnd - Date.now();
                if (timeLeft <= 0) return clearInterval(interval);
                var particleCount = 50 * (timeLeft / duration);
                confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.1, 0.3), y: Math.random() - 0.2 } }));
                confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.7, 0.9), y: Math.random() - 0.2 } }));
            }, 250);
        }

        function downloadEncryptedFile() {
            const blob = new Blob([window.finalEncryptedData], { type: "text/plain" });
            const link = document.createElement("a");
            link.href = URL.createObjectURL(blob);
            
            // Replaced candidateID with candidateName logic
            const safeName = aspirantName.replace(/[^a-zA-Z0-9]/g, '');
            link.download = `ExamData_${safeName}_${new Date().getTime()}.enc`;
            link.click();
        }

        // =========================================================================
        // EXAMINER PORTAL
        // =========================================================================
        function processExaminerFile() {
            const fileInput = document.getElementById('upload-enc');
            const pwdInput = document.getElementById('eval-password').value;
            const errorMsg = document.getElementById('login-error');

            if (fileInput.files.length === 0) {
                errorMsg.innerText = "Please select a .enc file.";
                errorMsg.classList.remove('hidden-screen');
                return;
            }

            const file = fileInput.files[0];
            const reader = new FileReader();

            reader.onload = function(e) {
                const encryptedContent = e.target.result;
                try {
                    const bytes = CryptoJS.AES.decrypt(encryptedContent, pwdInput);
                    const decryptedStr = bytes.toString(CryptoJS.enc.Utf8);
                    
                    if (!decryptedStr) throw new Error("Incorrect Password");
                    
                    const reportData = JSON.parse(decryptedStr);
                    errorMsg.classList.add('hidden-screen');
                    renderDashboard(reportData);
                } catch (err) {
                    errorMsg.innerText = "Decryption failed. Incorrect password or invalid file.";
                    errorMsg.classList.remove('hidden-screen');
                }
            };
            reader.readAsText(file);
        }

        function renderDashboard(data) {
            switchScreen('screen-examiner-dashboard');
            
            // Header Stats (Removed ID)
            document.getElementById('dash-candidate-name').innerText = `${data.candidateName}`;
            document.getElementById('dash-score').innerText = `${data.totalScore}/${data.totalQuestions}`;
            document.getElementById('dash-percentage').innerText = `${data.percentage}%`;
            
            // Section Bars
            const barsContainer = document.getElementById('dash-section-bars');
            barsContainer.innerHTML = '';
            const strongMods = [];
            const weakMods = [];

            Object.keys(data.sectionStats).forEach(mod => {
                const stat = data.sectionStats[mod];
                const pct = stat.total > 0 ? Math.round((stat.correct / stat.total) * 100) : 0;
                
                if (pct >= 80) strongMods.push(mod);
                else weakMods.push(mod);

                const colorClass = pct >= 80 ? 'bg-emerald-500' : (pct >= 50 ? 'bg-amber-400' : 'bg-red-500');

                barsContainer.innerHTML += `
                    <div>
                        <div class="flex justify-between text-xs font-semibold text-slate-600 mb-1">
                            <span>${mod}</span>
                            <span>${pct}% (${stat.correct}/${stat.total})</span>
                        </div>
                        <div class="w-full bg-slate-200 rounded-full h-2">
                            <div class="${colorClass} h-2 rounded-full" style="width: ${pct}%"></div>
                        </div>
                    </div>
                `;
            });

            // Strengths / Weaknesses
            document.getElementById('dash-strong').innerHTML = strongMods.map(m => `<li>${m}</li>`).join('') || '<li>None</li>';
            document.getElementById('dash-weak').innerHTML = weakMods.map(m => `<li>${m}</li>`).join('') || '<li>None</li>';

            // AI Recommendation
            let rec = "";
            if (weakMods.length === 0) rec = "Excellent overall comprehension. Candidate is highly prepared. Maintain revision rhythm.";
            else if (weakMods.includes("Quantitative Aptitude") || weakMods.includes("Logical Reasoning")) rec = "Immediate focus required on CSAT modules. Suggest rigorous practice of logical traps and time management in numerical applications. " + (weakMods.length > 2 ? "General Studies also need substantial revision." : "");
            else rec = "Candidate exhibits analytical gaps in General Studies. Recommend deeply reviewing the standard multi-statement and Assertion-Reasoning formats for: " + weakMods.join(", ") + ".";
            document.getElementById('dash-focus').innerText = rec;

            // Logs
            const logsContainer = document.getElementById('dash-logs');
            logsContainer.innerHTML = data.cheatLogs.map(l => `<p>${l}</p>`).join('');

            // Images
            const imagesContainer = document.getElementById('dash-images');
            imagesContainer.innerHTML = data.images.map(img => `<img src="${img}" class="h-24 rounded border border-slate-300 shadow-sm">`).join('');

            // Detailed Evaluation
            const evalContainer = document.getElementById('dash-evaluation');
            evalContainer.innerHTML = '';

            examData.questions.forEach((q, i) => {
                const userAnsIdx = data.candidateAnswers[q.id];
                const isCorrect = userAnsIdx === q.correctIndex;
                const statusColor = isCorrect ? 'text-emerald-600 bg-emerald-50' : (userAnsIdx === undefined ? 'text-slate-500 bg-slate-100' : 'text-red-600 bg-red-50');
                const statusIcon = isCorrect ? '✓ Correct' : (userAnsIdx === undefined ? '— Unanswered' : '✗ Incorrect');
                
                const userAnsText = userAnsIdx !== undefined ? String.fromCharCode(65 + userAnsIdx) + '. ' + q.options[userAnsIdx] : "None";
                const correctAnsText = String.fromCharCode(65 + q.correctIndex) + '. ' + q.options[q.correctIndex];
                
                // Enhanced Google Search Builder
                // Combines full question text + all options stringified for Google
                let fullSearchString = q.text + "\nOptions:\n";
                q.options.forEach((opt, optIdx) => {
                    fullSearchString += String.fromCharCode(65 + optIdx) + ". " + opt + "\n";
                });
                
                const query = encodeURIComponent(fullSearchString.trim());
                const googleLink = `https://www.google.com/search?q=${query}`;

                evalContainer.innerHTML += `
                    <div class="border border-slate-200 rounded-lg p-4 bg-slate-50 relative">
                        <div class="absolute top-4 right-4 text-xs font-bold px-2 py-1 rounded ${statusColor}">${statusIcon}</div>
                        <h4 class="text-sm font-semibold text-slate-800 mb-2 w-5/6">Q${i+1} [${q.module}]: ${q.text.replace(/\n/g, '<br/>')}</h4>
                        
                        <div class="grid md:grid-cols-2 gap-4 mt-4 text-sm">
                            <div>
                                <p class="text-slate-500 text-xs uppercase mb-1">Candidate Answer:</p>
                                <p class="font-medium ${isCorrect ? 'text-emerald-700' : 'text-red-700'}">${userAnsText}</p>
                            </div>
                            <div>
                                <p class="text-slate-500 text-xs uppercase mb-1">Correct Answer:</p>
                                <p class="font-medium text-slate-800">${correctAnsText}</p>
                            </div>
                        </div>

                        <div class="mt-4 p-3 bg-white rounded border border-slate-200 text-sm">
                            <p class="text-slate-600 text-xs uppercase font-bold mb-1">Logic / Trap Explanation:</p>
                            <p class="text-slate-700 italic">${q.explanation}</p>
                        </div>
                        
                        <div class="mt-4 flex justify-end">
                            <a href="${googleLink}" target="_blank" class="text-xs flex items-center gap-1 text-blue-600 hover:text-blue-800 font-medium">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                                Search Full Question on Google
                            </a>
                        </div>
                    </div>
                `;
            });
        }
    </script>
</body>
</html>
